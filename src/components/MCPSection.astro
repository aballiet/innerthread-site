---
---

<section class="mcp">
	<div class="container">
		<div class="section-intro" data-inview>
			<p class="section-tag reveal">Embedded Intelligence</p>
			<h2 class="reveal reveal-delay-1">Ask anything about your life.<br /><span class="highlight">Claude already has the context.</span></h2>
			<p class="intro-body reveal reveal-delay-2">
				"What was I obsessing about last March?" "Who introduced me to that idea?"
				Claude is embedded via the Agent SDK. You choose what it can see using labels
				and permission rules. Explore your own history or reflect on it. Your existing
				Claude subscription. No API key. No per-token cost.
			</p>
		</div>

		<div class="mcp-content" data-inview>
			<div class="tools-panel reveal reveal-delay-1">
				<div class="tools-cols">
					<div class="tools-col">
						<div class="tool-item">
							<span class="tool-name">get_context</span>
							<span class="tool-desc">full context for the current page</span>
						</div>
						<div class="tool-item">
							<span class="tool-name">execute_query</span>
							<span class="tool-desc">flexible SQL over your data</span>
						</div>
						<div class="tool-item">
							<span class="tool-name">semantic_search</span>
							<span class="tool-desc">vector similarity across all platforms</span>
						</div>
						<div class="tool-item">
							<span class="tool-name">get_stats</span>
							<span class="tool-desc">database overview and breakdown</span>
						</div>
					</div>
					<div class="tools-col">
						<div class="tool-item tool-item--label">
							<span class="tool-name">In-app chat</span>
							<span class="tool-desc">Claude embedded via Agent SDK</span>
						</div>
						<div class="tool-item tool-item--label">
							<span class="tool-name">MCP server</span>
							<span class="tool-desc">Also works with Claude Desktop</span>
						</div>
						<div class="tool-item tool-item--label">
							<span class="tool-name">Scope enforcement</span>
							<span class="tool-desc">Label-based access control per consumer</span>
						</div>
						<div class="tool-item tool-item--label">
							<span class="tool-name">Reflection write-back</span>
							<span class="tool-desc">Saves to app + Obsidian vault</span>
						</div>
					</div>
				</div>
			</div>

			<div class="callout-panel reveal reveal-delay-2">
				<div class="callout">
					<div class="callout-line">
						<span class="callout-speaker">You</span>
						<span class="callout-text">What idea have I kept coming back to?</span>
					</div>
					<div class="callout-divider"></div>
					<div class="callout-line">
						<span class="callout-speaker speaker-claude">Claude uses</span>
					</div>
					<div class="callout-tools">
						<code>get_topic_timeline(days=90)</code>
						<code>semantic_search("keep returning excited can't stop thinking")</code>
					</div>
					<div class="callout-divider"></div>
					<div class="callout-line">
						<span class="callout-speaker speaker-claude">Claude</span>
						<span class="callout-text">
							One thread runs through 23 conversations across three months: building
							something of your own. It shows up in a ChatGPT session in January,
							three WhatsApp voice-note transcripts in February, and six Claude
							conversations in March. Each time the tone is the same: energized,
							specific, a little scared. That's worth paying attention to.
						</span>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.mcp {
		background: var(--color-bg-alt);
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	.section-intro {
		text-align: center;
		max-width: 640px;
		margin: 0 auto var(--space-4xl);
	}

	.section-tag {
		display: inline-block;
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-teal);
		margin-bottom: var(--space-lg);
	}

	h2 {
		font-size: clamp(1.75rem, 4vw, 2.75rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1.2;
		margin-bottom: var(--space-lg);
	}

	.highlight {
		color: var(--color-accent);
	}

	.intro-body {
		color: var(--color-text-muted);
		font-size: 1.05rem;
		line-height: 1.7;
	}

	.mcp-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-2xl);
		align-items: start;
	}

	.tools-panel {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: var(--space-xl);
	}

	.tools-cols {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-sm) var(--space-xl);
	}

	.tool-item {
		display: flex;
		flex-direction: column;
		gap: 2px;
		padding: var(--space-sm) 0;
		border-bottom: 1px solid var(--color-border);
	}

	.tool-item:last-child {
		border-bottom: none;
	}

	.tool-name {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--color-teal);
	}

	.tool-item--label .tool-name {
		font-family: inherit;
		color: var(--color-text);
	}

	.tool-desc {
		font-size: 0.75rem;
		color: var(--color-text-faint);
		line-height: 1.4;
	}

	.callout-panel {
		position: sticky;
		top: 100px;
	}

	.callout {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-left: 3px solid var(--color-teal);
		border-radius: var(--radius-md);
		padding: var(--space-xl);
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
	}

	.callout-line {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	.callout-speaker {
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text-faint);
	}

	.speaker-claude {
		color: var(--color-teal);
	}

	.callout-text {
		font-size: 0.9rem;
		color: var(--color-text-muted);
		line-height: 1.65;
	}

	.callout-tools {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		padding-left: var(--space-md);
	}

	.callout-tools code {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		color: var(--color-teal);
		background: var(--color-teal-glow);
		padding: 0.2em 0.6em;
		border-radius: var(--radius-sm);
		display: inline-block;
		width: fit-content;
	}

	.callout-divider {
		height: 1px;
		background: var(--color-border);
	}

	@media (max-width: 900px) {
		.mcp-content {
			grid-template-columns: 1fr;
		}

		.callout-panel {
			position: static;
		}

		.tools-cols {
			grid-template-columns: 1fr;
		}
	}
</style>

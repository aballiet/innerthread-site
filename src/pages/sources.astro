interface SourceItem {
	name: string;
	method: string;
	desc: string;
	format: string;
	icon: string;
}

interface SourceGroup {
	group: string;
	label: string;
	items: SourceItem[];
}

const sources: SourceGroup[] = [
	{
		group: 'Browser extension',
		label: 'Auto-sync from your browser',
		items: [
			{ name: 'ChatGPT', method: 'Extension', desc: 'Background sync of all conversations. Rate-limited, completely silent.', format: 'API', icon: 'chatgpt' },
			{ name: 'Claude', method: 'Extension', desc: 'Background sync of all conversations. Same as ChatGPT.', format: 'API', icon: 'claude' },
		]
	},
	{
		group: 'Import',
		label: 'Drag and drop, format auto-detected',
		items: [
			{ name: 'WhatsApp', method: 'Import', desc: 'Export from the app as .txt. Multi-format support, group and DM.', format: '.txt', icon: 'whatsapp' },
			{ name: 'Messenger', method: 'Import', desc: 'Facebook "Download Your Information" JSON export.', format: '.json', icon: 'messenger' },
			{ name: 'Instagram', method: 'Import', desc: 'DM export with multi-file thread merging and encoding fixes.', format: '.json', icon: 'instagram' },
			{ name: 'SMS / MMS', method: 'Import', desc: 'XML from SMS Backup & Restore. Phone numbers normalized.', format: '.xml', icon: 'sms' },
			{ name: 'Google Keep', method: 'Import', desc: 'Notes and checklists from Google Takeout.', format: '.html', icon: 'keep' },
			{ name: 'Google Calendar', method: 'Import', desc: 'ICS file parsing with recurring event expansion and day grouping.', format: '.ics', icon: 'calendar' },
		]
	},
	{
		group: 'Live sync',
		label: 'Real-time, always up to date',
		items: [
			{ name: 'WhatsApp', method: 'Live', desc: 'Connect via QR code. Real-time messages via Baileys protocol. Auto-reconnect.', format: 'WebSocket', icon: 'whatsapp' },
			{ name: 'Obsidian', method: 'Live', desc: 'Vault filesystem watcher. Daily notes sync automatically.', format: '.md', icon: 'obsidian' },
		]
	}
];

const coming = ['Telegram', 'iMessage', 'Email (sent folder)', 'Gemini'];
---

<BaseLayout title="Sources - Retrace" description="Retrace reads from 10 sources. Import, sync, or connect live. Format is always auto-detected.">

<div class="page-header" data-inview>
	<div class="container">
		<h1 class="reveal">Every platform where you <span class="highlight">think and talk.</span></h1>
		<p class="reveal reveal-delay-1">
			Retrace reads from 10 sources. Import, sync, or connect live. Format is always auto-detected.
		</p>
	</div>
</div>

{sources.map((group, gi) => (
	<section class={`source-group${gi % 2 === 1 ? ' alt' : ''}`}>
		<div class="container">
			<div class="group-header" data-inview>
				<h2 class="reveal">{group.group}</h2>
				<p class="reveal reveal-delay-1">{group.label}</p>
			</div>

			<div class="source-grid" data-inview>
				{group.items.map((source, si) => (
					<div class="source-card reveal" style={`--delay: ${si * 100}ms`}>
						<div class="source-top">
							<span class="source-name">
								{icons[source.icon] && (
									<svg class="source-icon" width="22" height="22" viewBox="0 0 24 24" fill={icons[source.icon].color}>
										<path d={icons[source.icon].path}/>
									</svg>
								)}
								{source.name}
							</span>
							<span class="source-method">{source.method}</span>
						</div>
						<p class="source-desc">{source.desc}</p>
						<div class="source-format">
							<code>{source.format}</code>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>
))}

<section class="coming-soon">
	<div class="container">
		<div class="coming-content" data-inview>
			<h2 class="reveal">More sources coming</h2>
			<div class="coming-list reveal reveal-delay-1">
				{coming.map((name) => (
					<span class="coming-chip">{name}</span>
				))}
			</div>
			<p class="coming-note reveal reveal-delay-2">
				<a href="https://github.com/aballiet/retrace/blob/main/docs/roadmap.md" target="_blank" rel="noopener">
					See the full roadmap &rarr;
				</a>
			</p>
		</div>
	</div>
</section>

</BaseLayout>

<style>
	.page-header {
		padding-top: 140px;
		padding-bottom: var(--space-2xl);
		text-align: center;
	}

	.page-header h1 {
		font-size: clamp(2rem, 5vw, 3.25rem);
		font-weight: 700;
		letter-spacing: -0.03em;
		line-height: 1.15;
		margin-bottom: var(--space-lg);
	}

	.highlight {
		background: linear-gradient(135deg, var(--color-accent), var(--color-accent-light));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.page-header p {
		color: var(--color-text-muted);
		font-size: 1.15rem;
		max-width: 500px;
		margin: 0 auto;
		line-height: 1.7;
	}

	.source-group {
		padding: var(--space-4xl) 0;
	}

	.source-group.alt {
		background: var(--color-bg-alt);
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	.group-header {
		margin-bottom: var(--space-2xl);
	}

	.group-header h2 {
		font-size: clamp(1.5rem, 3vw, 2rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: var(--space-sm);
	}

	.group-header p {
		color: var(--color-text-muted);
		font-size: 1rem;
	}

	.source-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr));
		gap: var(--space-lg);
	}

	.source-card {
		padding: var(--space-xl);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		transition: all var(--duration-normal) ease;
		animation-delay: var(--delay);
	}

	.source-card:hover {
		border-color: var(--color-border-light);
		transform: translateY(-4px);
		box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
	}

	.source-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: var(--space-md);
	}

	.source-name {
		font-size: 1.1rem;
		font-weight: 650;
		letter-spacing: -0.01em;
		display: flex;
		align-items: center;
		gap: var(--space-sm);
	}

	.source-icon { flex-shrink: 0; }

	.source-method {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-teal);
		background: var(--color-teal-glow);
		padding: 0.2em 0.6em;
		border-radius: var(--radius-full);
	}

	.source-desc {
		color: var(--color-text-muted);
		font-size: 0.9rem;
		line-height: 1.6;
		margin-bottom: var(--space-md);
	}

	.source-format code {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		color: var(--color-text-faint);
		background: var(--color-bg-alt);
		padding: 0.2em 0.5em;
		border-radius: var(--radius-sm);
	}

	.coming-soon {
		padding: var(--space-4xl) 0;
		text-align: center;
	}

	.coming-soon h2 {
		font-size: clamp(1.5rem, 3vw, 2rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: var(--space-xl);
	}

	.coming-list {
		display: flex;
		gap: var(--space-sm);
		justify-content: center;
		flex-wrap: wrap;
		margin-bottom: var(--space-xl);
	}

	.coming-chip {
		font-size: 0.85rem;
		color: var(--color-text-faint);
		border: 1px dashed var(--color-border);
		padding: 0.4em 1em;
		border-radius: var(--radius-full);
	}

	.coming-note a {
		color: var(--color-accent);
		font-size: 0.95rem;
		font-weight: 500;
	}

	@media (max-width: 640px) {
		.page-header { padding-top: 100px; }
		.page-header h1 { font-size: clamp(1.75rem, 5vw, 2.5rem); }
		.source-card { padding: var(--space-lg); }
		.source-name { font-size: 1rem; }
	}
</style>

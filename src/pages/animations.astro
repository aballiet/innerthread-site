---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ConversationHub } from '../components/animations/ConversationHub';
import { TimeCapsulePipeline } from '../components/animations/TimeCapsulePipeline';
import { SearchFlow } from '../components/animations/SearchFlow';
---

<BaseLayout title="Animation Preview - Retrace">

<div class="page-header">
	<div class="container">
		<h1>Animation <span class="highlight">Preview</span></h1>
		<p>Explanatory animations showing how Retrace features work.</p>
	</div>
</div>

<section class="animation-section">
	<div class="container">
		<h2>Conversation Hub</h2>
		<p class="desc">Conversations from every platform flow into Retrace.</p>
		<div class="animation-frame">
			<ConversationHub client:visible />
		</div>
	</div>
</section>

<section class="animation-section alt">
	<div class="container">
		<h2>Time Capsule Pipeline</h2>
		<p class="desc">How Time Capsules work: your conversations are segmented, topics extracted, then an LLM reflects on what changed over time.</p>
		<div class="animation-frame">
			<TimeCapsulePipeline client:visible />
		</div>
	</div>
</section>

<section class="animation-section">
	<div class="container">
		<h2>Search Flow</h2>
		<p class="desc">How semantic search works: your query becomes a vector embedding, searches across all platforms in one shot.</p>
		<div class="animation-frame">
			<SearchFlow client:visible />
		</div>
	</div>
</section>

</BaseLayout>

<style>
	.page-header {
		padding-top: 140px;
		padding-bottom: var(--space-2xl);
		text-align: center;
	}

	.page-header h1 {
		font-size: clamp(2rem, 5vw, 3.25rem);
		font-weight: 700;
		letter-spacing: -0.03em;
		line-height: 1.15;
		margin-bottom: var(--space-lg);
	}

	.highlight {
		background: linear-gradient(135deg, var(--color-accent), var(--color-accent-light));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.page-header p {
		color: var(--color-text-muted);
		font-size: 1.15rem;
	}

	.animation-section {
		padding: var(--space-4xl) 0;
	}

	.animation-section.alt {
		background: var(--color-bg-alt);
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	h2 {
		font-size: clamp(1.5rem, 3vw, 2rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: var(--space-sm);
	}

	.desc {
		color: var(--color-text-muted);
		font-size: 1rem;
		max-width: 600px;
		margin-bottom: var(--space-2xl);
	}

	.animation-frame {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: var(--space-2xl);
		overflow: hidden;
	}

	@media (max-width: 640px) {
		.page-header { padding-top: 100px; }
		.animation-frame { padding: var(--space-md); }
	}
</style>
